{
  "name": "race-timer",
  "version": "1.0.9",
  "description": "A countdown timer application for Harpenden Arrows with runner management and announcements.",
  "main": "electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "build:ghpages": "ng build --base-href /race-timer/",
    "deploy:ghpages": "npm run build:ghpages && npx angular-cli-ghpages --dir=dist/race-timer",
    "build:electron": "ng build --base-href ./",
    "electron:start": "npm run build:electron && electron .",
    "electron:dist": "npm run build:electron && npx electron-packager . \"Harpenden Arrows Race Timer\" --platform=win32 --arch=x64 --out=release --overwrite --ignore=node_modules --ignore=src --ignore=.angular --ignore=release && powershell -Command \"Compress-Archive -Path 'release/Harpenden Arrows Race Timer-win32-x64' -DestinationPath 'release/HarpendenArrowsRaceTimer.zip' -Force\"",
    "release": "node scripts/release.js"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^18.0.0",
    "@angular/core": "^18.0.0",
    "@angular/forms": "^18.0.0",
    "@angular/platform-browser": "^18.0.0",
    "@angular/platform-browser-dynamic": "^18.0.0",
    "@angular/router": "^18.0.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "^0.14.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.0.0",
    "@angular/cli": "^18.0.0",
    "@angular/compiler-cli": "^18.0.0",
    "@types/node": "^20.0.0",
    "angular-cli-ghpages": "^3.0.2",
    "cross-env": "^10.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "typescript": "~5.4.0"
  },
  "build": {
    "appId": "com.harpendenarrows.racetimer",
    "productName": "Harpenden Arrows Race Timer",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "src/favicon.ico"
    },
    "nsis": {
      "oneClick": true,
      "shortcutName": "Harpenden Arrows Race Timer"
    }
  },
  "engines": {
    "node": ">=12.0.0"
  }
}
